#!/usr/bin/env bash
#MISE description="Retrieve a secret from macOS Keychain"
#USAGE arg "<key>" help="Secret key (e.g., baby-joel/github-pat)"

set -eo pipefail

KEY="${usage_key:-${1:?Usage: secrets keychain:get <key>}}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

source "$LIB_DIR/keychain.sh"
keychain_get "$KEY"
