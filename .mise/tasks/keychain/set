#!/usr/bin/env bash
#MISE description="Store a secret in macOS Keychain"
#USAGE arg "<key>" help="Secret key (e.g., baby-joel/github-pat)"
#USAGE flag "-v --value <value>" help="Value to store (or pipe via stdin)"

set -eo pipefail

KEY="${usage_key:-${1:?Usage: secrets keychain:set <key>}}"
VALUE="${usage_value:-}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

source "$LIB_DIR/keychain.sh"

if [ -n "$VALUE" ]; then
  keychain_set "$KEY" "$VALUE"
else
  keychain_set "$KEY"
fi
