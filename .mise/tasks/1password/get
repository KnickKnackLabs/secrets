#!/usr/bin/env bash
#MISE description="Retrieve a secret from 1Password"
#USAGE arg "<key>" help="Secret key (e.g., baby-joel/github-pat)"

set -eo pipefail

KEY="${usage_key:-${1:?Usage: secrets 1password:get <key>}}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

source "$LIB_DIR/1password.sh"
op_get "$KEY"
