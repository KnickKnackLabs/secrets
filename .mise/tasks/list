#!/usr/bin/env bash
#MISE description="List stored secrets for an agent"
#USAGE arg "[agent]" help="Agent name (required for provider lookups)"
#USAGE flag "-p --provider <provider>" help="Provider: keychain or 1password (overrides SECRETS_PROVIDER)"

set -eo pipefail

AGENT="${usage_agent:-}"
PROVIDER="${usage_provider:-${SECRETS_PROVIDER:-}}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

if [ -z "$PROVIDER" ]; then
  echo "Usage: secrets list <agent> [--provider <provider>]" >&2
  echo "" >&2
  echo "Set SECRETS_PROVIDER=keychain|1password (or --provider) to list stored secrets." >&2
  exit 1
fi

case "$PROVIDER" in
  keychain)
    source "$LIB_DIR/keychain.sh"
    echo "Keychain secrets${AGENT:+ for $AGENT}:"
    keychain_list "$AGENT"
    ;;
  1password)
    source "$LIB_DIR/1password.sh"
    echo "1Password secrets${AGENT:+ for $AGENT}:"
    op_list "$AGENT"
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    echo "       Valid providers: keychain, 1password" >&2
    exit 1
    ;;
esac
