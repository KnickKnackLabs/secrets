#!/usr/bin/env bash
#MISE description="List stored secrets"
#USAGE arg "[prefix]" help="Optional prefix to filter keys (e.g., baby-joel)"
#USAGE flag "-p --provider <provider>" help="Provider: keychain or 1password (overrides SECRETS_PROVIDER)"

set -eo pipefail

PREFIX="${usage_prefix:-}"
PROVIDER="${usage_provider:-${SECRETS_PROVIDER:-}}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

if [ -z "$PROVIDER" ]; then
  echo "Usage: secrets list [prefix] [--provider <provider>]" >&2
  echo "" >&2
  echo "Set SECRETS_PROVIDER=keychain|1password (or --provider) to list stored secrets." >&2
  exit 1
fi

case "$PROVIDER" in
  keychain)
    source "$LIB_DIR/keychain.sh"
    echo "Keychain secrets${PREFIX:+ (prefix: $PREFIX)}:"
    keychain_list "$PREFIX"
    ;;
  1password)
    source "$LIB_DIR/1password.sh"
    echo "1Password secrets${PREFIX:+ (prefix: $PREFIX)}:"
    op_list "$PREFIX"
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    echo "       Valid providers: keychain, 1password" >&2
    exit 1
    ;;
esac
