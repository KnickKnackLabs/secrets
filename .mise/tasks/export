#!/usr/bin/env bash
#MISE description="Export secrets as a JSON bundle (stdout)"
#USAGE flag "--prefix <prefix>" help="Filter keys by prefix (e.g., baby-joel)"
#USAGE flag "-p --provider <provider>" help="Provider: keychain or 1password (overrides SECRETS_PROVIDER)"
#USAGE long_about "Export secrets as plain JSON to stdout.\n\nKeys are exported with their full names. Use --prefix to filter to a subset.\nOutput is unencrypted — pipe through gpg if you need encryption.\n\nExamples:\n  secrets export --prefix baby-joel\n  secrets export --prefix baby-joel | gpg -e -r baby-joel@ricon.family > bundle.gpg\n  secrets export --prefix baby-joel -p 1password | secrets import -p keychain"

set -eo pipefail

PREFIX="${usage_prefix:-}"
PROVIDER="${usage_provider:-${SECRETS_PROVIDER:-}}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SECRETS_PROVIDER=keychain|1password, or use --provider <provider>" >&2
  exit 1
fi

# Discover keys for this prefix
case "$PROVIDER" in
  keychain)
    source "$LIB_DIR/keychain.sh"
    keys=$(_keychain_discover_keys "$PREFIX")
    get_fn="keychain_get"
    ;;
  1password)
    source "$LIB_DIR/1password.sh"
    keys=$(_op_discover_keys "$PREFIX") || exit 1
    get_fn="op_get"
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    exit 1
    ;;
esac

if [ -z "$keys" ]; then
  echo "ERROR: No secrets found for prefix=$PREFIX in provider=$PROVIDER" >&2
  exit 1
fi

# Build JSON object: { "key1": "value1", "key2": "value2", ... }
# Keys are exported with their full names (no stripping).
json="{"
first=true
while IFS= read -r key; do
  [ -z "$key" ] && continue
  value=$("$get_fn" "$key") || {
    echo "WARNING: Failed to read key=$key, skipping" >&2
    continue
  }
  # Strip wrapping double-quotes from double-encoded values.
  if [[ "$value" == '"'*'"' ]]; then
    value="${value#\"}"
    value="${value%\"}"
  fi
  # JSON-escape the value (handle newlines, quotes, backslashes)
  escaped_value=$(printf '%s' "$value" | jq -Rs '.')
  if [ "$first" = true ]; then
    first=false
  else
    json+=","
  fi
  json+="$(printf '"%s":%s' "$key" "$escaped_value")"
done <<< "$keys"
json+="}"

# Validate and output the JSON
echo "$json" | jq . >/dev/null 2>&1 || {
  echo "ERROR: Failed to build valid JSON bundle" >&2
  exit 1
}

echo "$json"
