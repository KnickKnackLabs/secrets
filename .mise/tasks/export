#!/usr/bin/env bash
#MISE description="Export secrets as a GPG-encrypted JSON bundle"
#USAGE arg "<prefix>" help="Key prefix to export (e.g., baby-joel)"
#USAGE flag "-p --provider <provider>" help="Provider: keychain or 1password (overrides SECRETS_PROVIDER)"
#USAGE flag "--encrypt-to <recipient>" help="GPG recipient (default: <prefix>@ricon.family)"

set -eo pipefail

PREFIX="${usage_prefix:?}"
PROVIDER="${usage_provider:-${SECRETS_PROVIDER:-}}"
ENCRYPT_TO="${usage_encrypt_to:-${PREFIX}@ricon.family}"
LIB_DIR="${MISE_CONFIG_ROOT:?}/lib"

: "${GPG:=gpg}"

if ! command -v "$GPG" &>/dev/null; then
  echo "ERROR: GPG not found. Install gnupg (e.g., brew install gnupg)." >&2
  echo "       GPG is required to encrypt the export bundle." >&2
  exit 1
fi

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SECRETS_PROVIDER=keychain|1password, or use --provider <provider>" >&2
  exit 1
fi

# Discover keys for this prefix
case "$PROVIDER" in
  keychain)
    source "$LIB_DIR/keychain.sh"
    keys=$(_keychain_discover_keys "$PREFIX")
    get_fn="keychain_get"
    ;;
  1password)
    source "$LIB_DIR/1password.sh"
    keys=$(_op_discover_keys "$PREFIX") || exit 1
    get_fn="op_get"
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    exit 1
    ;;
esac

if [ -z "$keys" ]; then
  echo "ERROR: No secrets found for prefix=$PREFIX in provider=$PROVIDER" >&2
  exit 1
fi

# Build JSON object: { "key1": "value1", "key2": "value2", ... }
# Keys in the bundle are relative (prefix stripped).
json="{"
first=true
while IFS= read -r key; do
  [ -z "$key" ] && continue
  # Fetch using full key (prefix/key)
  value=$("$get_fn" "${PREFIX}/${key}") || {
    echo "WARNING: Failed to read key=$key, skipping" >&2
    continue
  }
  # Strip wrapping double-quotes from double-encoded values.
  if [[ "$value" == '"'*'"' ]]; then
    value="${value#\"}"
    value="${value%\"}"
  fi
  # JSON-escape the value (handle newlines, quotes, backslashes)
  escaped_value=$(printf '%s' "$value" | jq -Rs '.')
  if [ "$first" = true ]; then
    first=false
  else
    json+=","
  fi
  json+="$(printf '"%s":%s' "$key" "$escaped_value")"
done <<< "$keys"
json+="}"

# Validate the JSON
echo "$json" | jq . >/dev/null 2>&1 || {
  echo "ERROR: Failed to build valid JSON bundle" >&2
  exit 1
}

# Encrypt with GPG and output to stdout
echo "$json" | "$GPG" --encrypt --armor --recipient "$ENCRYPT_TO" --trust-model always
